      const allJobs = <%- JSON.stringify(jobs) %>;
      
      // Filter jobs that will be affected (Active → Ignored, Pending → Active)
      const affectedJobs = allJobs.filter(job => job.state === 'Active' || job.state === 'Pending');
      
      // Populate the job list
